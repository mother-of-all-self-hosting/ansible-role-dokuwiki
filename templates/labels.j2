{% if dokuwiki_container_labels_traefik_enabled %}
traefik.enable=true

{% if dokuwiki_container_labels_traefik_docker_network %}
traefik.docker.network={{ dokuwiki_container_labels_traefik_docker_network }}
{% endif %}

{% set middlewares = [] %}

{% if dokuwiki_container_labels_traefik_path_prefix != '/' %}
traefik.http.middlewares.{{ dokuwiki_identifier }}-slashless-redirect.redirectregex.regex=^({{ dokuwiki_container_labels_traefik_path_prefix | quote }})$
traefik.http.middlewares.{{ dokuwiki_identifier }}-slashless-redirect.redirectregex.replacement=${1}/
{% set middlewares = middlewares + [dokuwiki_identifier + '-slashless-redirect'] %}
{% endif %}

{% if dokuwiki_container_labels_traefik_path_prefix != '/' %}
traefik.http.middlewares.{{ dokuwiki_identifier }}-strip-prefix.stripprefix.prefixes={{ dokuwiki_container_labels_traefik_path_prefix }}
{% set middlewares = middlewares + [dokuwiki_identifier + '-strip-prefix'] %}
{% endif %}

{% if dokuwiki_container_labels_traefik_additional_request_headers.keys() | length > 0 %}
{% for name, value in dokuwiki_container_labels_traefik_additional_request_headers.items() %}
traefik.http.middlewares.{{ dokuwiki_identifier }}-add-request-headers.headers.customrequestheaders.{{ name }}={{ value }}
{% endfor %}
{% set middlewares = middlewares + [dokuwiki_identifier + '-add-request-headers'] %}
{% endif %}

{% if dokuwiki_container_labels_traefik_additional_response_headers.keys() | length > 0 %}
{% for name, value in dokuwiki_container_labels_traefik_additional_response_headers.items() %}
traefik.http.middlewares.{{ dokuwiki_identifier }}-add-response-headers.headers.customresponseheaders.{{ name }}={{ value }}
{% endfor %}
{% set middlewares = middlewares + [dokuwiki_identifier + '-add-response-headers'] %}
{% endif %}

traefik.http.routers.{{ dokuwiki_identifier }}.rule={{ dokuwiki_container_labels_traefik_rule }}
{% if dokuwiki_container_labels_traefik_priority | int > 0 %}
traefik.http.routers.{{ dokuwiki_identifier }}.priority={{ dokuwiki_container_labels_traefik_priority }}
{% endif %}
traefik.http.routers.{{ dokuwiki_identifier }}.service={{ dokuwiki_identifier }}
{% if middlewares | length > 0 %}
traefik.http.routers.{{ dokuwiki_identifier }}.middlewares={{ middlewares | join(',') }}
{% endif %}
traefik.http.routers.{{ dokuwiki_identifier }}.entrypoints={{ dokuwiki_container_labels_traefik_entrypoints }}
traefik.http.routers.{{ dokuwiki_identifier }}.tls={{ dokuwiki_container_labels_traefik_tls | to_json }}
{% if dokuwiki_container_labels_traefik_tls %}
traefik.http.routers.{{ dokuwiki_identifier }}.tls.certResolver={{ dokuwiki_container_labels_traefik_tls_certResolver }}
{% endif %}

traefik.http.services.{{ dokuwiki_identifier }}.loadbalancer.server.port={{ dokuwiki_container_http_port }}
{% endif %}

{% for arg in dokuwiki_container_labels_additional_labels %}
{{ arg }}
{% endfor %}
